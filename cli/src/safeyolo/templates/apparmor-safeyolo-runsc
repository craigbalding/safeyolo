abi <abi/4.0>,
include <tunables/global>

# SafeYolo AppArmor profile for runsc (gVisor).
#
# Ubuntu 24.04+ restricts unprivileged user namespace creation via
# AppArmor. This profile allows runsc to create user namespaces,
# which SafeYolo uses for rootless container isolation (loopback-only
# network namespace + gVisor sandbox).
#
# Install automatically:
#   safeyolo setup apparmor      # just this step
#   safeyolo setup               # this step + KVM udev rule
#
# Or by hand:
#   sudo cp apparmor-safeyolo-runsc /etc/apparmor.d/safeyolo-runsc
#   sudo apparmor_parser -r /etc/apparmor.d/safeyolo-runsc

profile safeyolo-runsc /usr/local/bin/runsc flags=(unconfined) {
  userns,
}
