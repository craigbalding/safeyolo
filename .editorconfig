root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Python (as per ruff.toml)
[*.py]
indent_size = 4
max_line_length = 120

# Shell scripts
[*.sh]
indent_size = 4
trim_trailing_whitespace = false

# Markdown, JSON, TOML, YAML
[*.{md,mdx,json,toml,yml,yaml}]
indent_size = 2
trim_trailing_whitespace = false

# TypeScript/JavaScript/CSS (global default)
[*.{ts,tsx,js,jsx,css}]
indent_size = 2

# CHANGELOG.md: no specific indent size
[CHANGELOG.md]
indent_size = false
