# SafeYolo Extended Policy Example
#
# Additional host entries and addon configuration.
# Merge sections you need into your policy.yaml and addons.yaml.
#
# This file contains settings removed from the default baseline to keep it
# focused on common AI coding agent use cases.

# =============================================================================
# ADDITIONAL HOST ENTRIES
# =============================================================================
# Merge these into the hosts section of policy.yaml.
# Each host entry defines credentials, rate_limit, and optional bypass.

hosts:
  # ---------------------------------------------------------------------------
  # Apify / MCP
  # ---------------------------------------------------------------------------
  api.apify.com:             { rate_limit: 1800 }   # 30 rps
  mcp.apify.com:             { rate_limit: 1800 }   # 30 rps

  # ---------------------------------------------------------------------------
  # Telegram
  # ---------------------------------------------------------------------------
  api.telegram.org:          { rate_limit: 1800 }   # 30 rps

  # ---------------------------------------------------------------------------
  # Telemetry (high volume)
  # ---------------------------------------------------------------------------
  statsig.anthropic.com:     { rate_limit: 12000, bypass: [prompt_injection] }  # 200 rps

  # ---------------------------------------------------------------------------
  # Sentry
  # ---------------------------------------------------------------------------
  "*.sentry.io":             { rate_limit: 1200 }   # 20 rps

  # ---------------------------------------------------------------------------
  # Go module proxy storage
  # ---------------------------------------------------------------------------
  storage.googleapis.com:    { rate_limit: 300 }     # 5 rps

  # ---------------------------------------------------------------------------
  # Media sites (conservative)
  # ---------------------------------------------------------------------------
  "*.youtube.com":           { rate_limit: 12 }      # 0.2 rps
  "*.googlevideo.com":       { rate_limit: 30 }      # 0.5 rps
  "*.soundcloud.com":        { rate_limit: 30 }      # 0.5 rps

  # ---------------------------------------------------------------------------
  # Podcast hosts (conservative)
  # ---------------------------------------------------------------------------
  "*.podbean.com":           { rate_limit: 60 }      # 1 rps
  "*.libsyn.com":            { rate_limit: 60 }
  "*.buzzsprout.com":        { rate_limit: 60 }
  "*.anchor.fm":             { rate_limit: 60 }
  "*.spreaker.com":          { rate_limit: 60 }
  "*.simplecast.com":        { rate_limit: 60 }
  "*.transistor.fm":         { rate_limit: 60 }
  "*.captivate.fm":          { rate_limit: 60 }
  "*.megaphone.fm":          { rate_limit: 60 }
  "*.omnycontent.com":       { rate_limit: 60 }
  "*.acast.com":             { rate_limit: 60 }

  # ---------------------------------------------------------------------------
  # Ntfy notifications
  # ---------------------------------------------------------------------------
  slim-horse.pikapod.net:    { rate_limit: 600 }     # 10 rps

  # ---------------------------------------------------------------------------
  # Package registries — skip heavy scanning
  # ---------------------------------------------------------------------------
  pypi.org:                  { bypass: [yara_scanner, prompt_injection] }
  registry.npmjs.org:        { bypass: [yara_scanner, prompt_injection] }
  proxy.golang.org:          { bypass: [yara_scanner, prompt_injection] }
  sum.golang.org:            { bypass: [yara_scanner, prompt_injection] }

  # ---------------------------------------------------------------------------
  # Telemetry — skip injection detection
  # ---------------------------------------------------------------------------
  "*.datadoghq.com":         { bypass: [prompt_injection] }
  "*.segment.io":            { bypass: [prompt_injection] }

# =============================================================================
# ADDITIONAL ADDON CONFIGURATION
# =============================================================================
# Merge these into addons.yaml (sibling to policy.yaml)

addons:
  yara_scanner:
    enabled: true

  prompt_injection:
    enabled: false  # Requires classifier service

  sse_streaming:
    enabled: false  # Enabled per-host below

# =============================================================================
# CLIENT OVERRIDES
# =============================================================================
# Add this section to policy.yaml

clients:
  # Admin clients bypass pattern scanning
  "admin-*":
    bypass:
      - pattern_scanner

  # Test clients bypass rate limiting (for integration tests)
  "test-*":
    addons:
      network_guard:
        enabled: false

  # Unknown principals (source IP not resolved via Docker DNS)
  # This happens when:
  #   - A request came from an IP that Docker DNS can't reverse-resolve
  #   - An external IP somehow reached the proxy
  # Policy: Allow with logging - don't break things, but make it visible
  "unknown":
    log_level: warning
    # Use default rate limits, don't bypass any security checks
