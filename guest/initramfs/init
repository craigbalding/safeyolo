#!/bin/sh
#
# SafeYolo initramfs init — erofs base + per-agent ext4 overlay upper.
#
# /dev/vda is the shared read-only EROFS base image. /dev/vdb, when
# present, is a per-agent ext4-backed writable disk that holds the
# overlayfs upper+work layers; runtime writes to / persist across
# agent stop/run in this file. When /dev/vdb is absent, we fall back
# to a tmpfs upper (ephemeral, same as the historical behavior).
#
# Layout:
#   /mnt/lower        = read-only erofs (/dev/vda)
#   /mnt/overlay      = ext4 on /dev/vdb (persistent) OR tmpfs (fallback)
#     /upper          = overlayfs upper (writable)
#     /work           = overlayfs work dir (same FS as upper, required)
#   /mnt/root         = overlayfs mount (the new /)
#
# First-boot handling: a freshly-created /dev/vdb image is unformatted
# raw bytes. The `mount` attempt fails; we mkfs.ext4 and retry. On
# subsequent boots the filesystem is there and mount succeeds first try.
#
set -e

mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devtmpfs dev /dev

# Mountpoints for the overlay stack. build-initramfs.sh pre-creates
# /mnt/root; creating the other two here keeps the build script
# agnostic to the init's mount topology.
mkdir -p /mnt/lower /mnt/overlay

# Read-only EROFS base
mount -t erofs -o ro /dev/vda /mnt/lower

# Writable upper layer on /dev/vdb (persistent ext4, per-agent).
# /dev/vdb MUST be attached — the host's safeyolo-vm helper is
# responsible for creating and attaching a per-agent overlay image.
# No tmpfs fallback: silent-demotion to ephemeral would make a
# misconfigured host look like normal operation while losing every
# write the agent makes to /etc, /usr, /var. Panic with a clear
# message instead so the failure is visible.
if [ ! -b /dev/vdb ]; then
    echo "initramfs FATAL: /dev/vdb not attached — the host must pass --overlay PATH to safeyolo-vm so per-agent writes persist. Refusing to boot with an ephemeral upper layer (that silently loses changes)." >&2
    exec sleep infinity
fi

# First-boot: mount attempt fails on a freshly-truncated sparse file
# (no superblock). mkfs.ext4 in place and retry. On subsequent boots
# the filesystem is already there and the first mount succeeds.
if ! mount -t ext4 /dev/vdb /mnt/overlay 2>/dev/null; then
    echo "initramfs: /dev/vdb has no filesystem, formatting ext4 (first boot)"
    /sbin/mkfs.ext4 -F -q -E lazy_itable_init=1 /dev/vdb
    mount -t ext4 /dev/vdb /mnt/overlay
fi
mkdir -p /mnt/overlay/upper /mnt/overlay/work

mount -t overlay overlay \
    -o lowerdir=/mnt/lower,upperdir=/mnt/overlay/upper,workdir=/mnt/overlay/work \
    /mnt/root

# Read network config from the host-supplied config share.
# virtiofs on a second tag — mounted transiently here so the init can
# read network.env; the main orchestrator remounts it (and the other
# tags) after switch_root.
mkdir -p /mnt/config
mount -t virtiofs config /mnt/config 2>/dev/null || true

if ip link show eth0 >/dev/null 2>&1; then
    ip link set eth0 up
    if [ -f /mnt/config/network.env ]; then
        . /mnt/config/network.env
        ip addr add ${GUEST_IP}/${NETMASK:-255.255.255.0} dev eth0
        ip route add default via ${GATEWAY_IP}
    fi
fi

umount /mnt/config 2>/dev/null || true

# Clean up initramfs-root mounts before switch_root. /mnt/lower (erofs)
# and /mnt/overlay (tmpfs upper/work) are held by overlayfs; they stay.
# The rootfs-baked safeyolo-guest-init stub re-mounts /proc /sys /dev
# on the new root as its first act (see guest/rootfs/safeyolo-guest-init).
umount /proc /sys /dev

exec switch_root /mnt/root /usr/local/bin/safeyolo-guest-init
